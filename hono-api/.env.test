# NOTE: nama DB ini hanya TEMPLATE. Saat `bun test` jalan, tests/setup.ts akan:
#   1. Ambil host/user/pass/port dari URL ini
#   2. Bikin DB baru bernama `msf_test_{timestamp}_{pid}` (suffix `_test` wajib)
#   3. Override process.env.DATABASE_URL ke DB tsb sebelum modul src/* di-import
#   4. DROP DB itu setelah semua test selesai
# DB "msf_test" tidak perlu sudah ada — hanya host/credentials yang dipakai.
DATABASE_URL=postgres://msf:msf@localhost:5432/msf_test
JWT_SECRET=test-secret-min-16-chars-aaaaaaaa
JWT_EXPIRES_IN=3600
NODE_ENV=test
PORT=3001
