# PostgreSQL target (new mobile + cron sync destination)
# Default value cocok dengan docker-compose.yml (user=msf, pass=msf, db=msf)
DATABASE_URL=postgres://msf:msf@localhost:5432/msf

# MariaDB source (legacy, read-only — dipakai oleh `bun run db:sync-master`)
# Format: mysql://user:password@host:port/dbname
# Contoh: mysql://project:secret@mersimkt.web.id:3306/monitoring
# Kosongkan / un-set kalau belum perlu sync.
LEGACY_MARIADB_URL=

# Optional: bypass deadline add call_list untuk periode tertentu (format YYYY-MM).
# Berguna untuk hot-fix tanpa rilis ulang APK. Lihat src/lib/constants.ts.
OVERRIDE_BULAN_LIST=

# === Restore dev DB dari legacy SQL dump (script `bun run db:restore-legacy`) ===
# Folder berisi *.sql hasil ekstrak mysqldump (lihat ../legacy/db-backup/README.md).
# Default kalau di-unset: ../legacy/db-backup (relative dari hono-api/).
LEGACY_DUMP_DIR=../legacy/db-backup
# Safety opt-in. Script refuse jalan tanpa ini diset ke 'true' — biar
# tidak accidental jalan & nimpa DB.
ALLOW_LEGACY_RESTORE=

# App
PORT=3000
NODE_ENV=development

# AWS S3 (for file uploads)
AWS_S3_ENDPOINT=https://is3.cloudhost.id
AWS_ACCESS_KEY_ID=FV60WC1QZRGK110KO625
AWS_SECRET_ACCESS_KEY=35VmsM0MPuU9QJ15SxTzAuewVYR6quWE8ZpnDCY1
AWS_REGION=SouthJKT-a
AWS_S3_BUCKET=files3
