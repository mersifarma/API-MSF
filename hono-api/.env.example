# PostgreSQL target (new mobile + cron sync destination)
# Default value cocok dengan docker-compose.yml (user=msf, pass=msf, db=msf)
DATABASE_URL=postgres://msf:msf@localhost:5432/msf

# MariaDB source (legacy, read-only — untuk cron sync master)
LEGACY_MYSQL_HOST=mersimkt.web.id
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_DATABASE=monitoring
LEGACY_MYSQL_USERNAME=project
LEGACY_MYSQL_PASSWORD=

# App
PORT=3000
NODE_ENV=development

# JWT auth — gantikan plain id_peg di body (legacy)
# Production: set ke string random panjang (mis. `openssl rand -hex 32`)
JWT_SECRET=change-me-in-production-min-16-chars
# Expiry dalam detik (default 7 hari = 604800)
JWT_EXPIRES_IN=604800
