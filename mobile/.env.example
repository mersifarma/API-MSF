# Base URL ke hono-api. Default fallback di src/config/env.ts = http://10.0.2.2:8001
# (port 8001 = nilai PORT di hono-api/.env)
#
#  - Android emulator      → http://10.0.2.2:8001
#  - iOS simulator / web   → http://localhost:8001
#  - Physical device (LAN) → http://<dev-machine-ip>:8001  (mis. http://192.168.1.10:8001)
#  - Staging               → https://registrasi.mersimkt.web.id/api/dev
#  - Production            → https://registrasi.mersimkt.web.id/api
EXPO_PUBLIC_API_URL=http://10.0.2.2:8001
